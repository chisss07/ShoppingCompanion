# ============================================================
# Shopping Companion - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# ============================================================

# --- App ---
APP_ENV=development
DEBUG=true
LOG_LEVEL=debug
SECRET_KEY=change-me-to-a-random-64-char-string

# --- Database (PostgreSQL) ---
POSTGRES_USER=shopping
POSTGRES_PASSWORD=changeme
POSTGRES_DB=shoppingcompanion
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://shopping:changeme@postgres:5432/shoppingcompanion

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Shopping APIs (Tier 1) ---
# Amazon Product Advertising API
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# Best Buy
BESTBUY_API_KEY=

# Walmart
WALMART_CONSUMER_ID=
WALMART_PRIVATE_KEY=

# Google Shopping via SerpAPI
SERPAPI_KEY=

# eBay
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_OAUTH_TOKEN=

# --- Rate Limiting ---
SEARCH_RATE_LIMIT_PER_MINUTE=10
SEARCH_RATE_LIMIT_PER_DAY=200

# --- WebSocket ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# --- Playwright (internal service) ---
PLAYWRIGHT_WS_ENDPOINT=ws://playwright:3000
