<?xml version="1.0"?>
<Container version="2">
  <Name>shopping-companion</Name>
  <Repository>chisss/shoppingcompanion-frontend:latest</Repository>
  <Registry>https://hub.docker.com/r/chisss/shoppingcompanion-frontend</Registry>
  <Network>shopping-companion</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Overview>
    AI-powered shopping assistant that compares prices across Amazon, Best Buy, Walmart,
    eBay, and more — with real-time WebSocket progress and Claude AI summaries.
    Uses Docker Compose Manager. See: https://github.com/chisss07/ShoppingCompanion
  </Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:80]/</WebUI>
  <Icon>https://raw.githubusercontent.com/chisss07/ShoppingCompanion/main/docs/icon.png</Icon>
  <Description>
    AI-powered shopping price comparison tool. Searches major retailers in parallel,
    ranks results by deal score, and provides Claude AI-generated summaries and
    alternative model recommendations. Real-time progress via WebSocket.
    Requires Docker Compose Manager plugin.
  </Description>
  <Project>https://github.com/chisss07/ShoppingCompanion</Project>

  <!-- ═══════════════════════════════════════════════════════════
       PORTS
  ═══════════════════════════════════════════════════════════ -->
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8090</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>Web UI (nginx frontend)</Description>
      </Port>
    </Publish>
  </Networking>

  <!-- ═══════════════════════════════════════════════════════════
       VOLUMES
  ═══════════════════════════════════════════════════════════ -->
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/shopping-companion/postgres</HostDir>
      <ContainerDir>/var/lib/postgresql/data</ContainerDir>
      <Mode>rw</Mode>
      <Mask>755</Mask>
      <Name>postgres-data</Name>
      <Description>PostgreSQL database files</Description>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/shopping-companion/redis</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
      <Mask>755</Mask>
      <Name>redis-data</Name>
      <Description>Redis persistence data</Description>
    </Volume>
  </Data>

  <!-- ═══════════════════════════════════════════════════════════
       ENVIRONMENT VARIABLES
  ═══════════════════════════════════════════════════════════ -->

  <!-- ── App ── -->
  <Environment>
    <Variable>
      <Value>production</Value>
      <Name>APP_ENV</Name>
      <Mode/>
      <Description>Application environment (production / development)</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>SECRET_KEY</Name>
      <Mode/>
      <Description>Random 64-character secret key. Generate with: openssl rand -hex 32</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>true</Mask>
    </Variable>

    <!-- ── Database ── -->
    <Variable>
      <Value>shopping</Value>
      <Name>POSTGRES_USER</Name>
      <Mode/>
      <Description>PostgreSQL username</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>false</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>POSTGRES_PASSWORD</Name>
      <Mode/>
      <Description>PostgreSQL password — choose a strong password</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value>shoppingcompanion</Value>
      <Name>POSTGRES_DB</Name>
      <Mode/>
      <Description>PostgreSQL database name</Description>
      <Display>advanced</Display>
      <Required>true</Required>
      <Mask>false</Mask>
    </Variable>

    <!-- ── AI ── -->
    <Variable>
      <Value></Value>
      <Name>ANTHROPIC_API_KEY</Name>
      <Mode/>
      <Description>Anthropic Claude API key — get one at console.anthropic.com. Required for AI summaries and alternative model detection.</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>true</Mask>
    </Variable>

    <!-- ── Shopping APIs ── -->
    <Variable>
      <Value></Value>
      <Name>BESTBUY_API_KEY</Name>
      <Mode/>
      <Description>Best Buy Products API key — developer.bestbuy.com</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>SERPAPI_KEY</Name>
      <Mode/>
      <Description>SerpAPI key (Google Shopping results) — serpapi.com</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>EBAY_APP_ID</Name>
      <Mode/>
      <Description>eBay Browse API App ID — developer.ebay.com</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>EBAY_CERT_ID</Name>
      <Mode/>
      <Description>eBay Browse API Cert ID</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>EBAY_OAUTH_TOKEN</Name>
      <Mode/>
      <Description>eBay OAuth Client Credentials token</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>AMAZON_ACCESS_KEY</Name>
      <Mode/>
      <Description>Amazon Product Advertising API 5.0 Access Key</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>AMAZON_SECRET_KEY</Name>
      <Mode/>
      <Description>Amazon Product Advertising API 5.0 Secret Key</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>AMAZON_PARTNER_TAG</Name>
      <Mode/>
      <Description>Amazon Associates Partner Tag (e.g. mysite-20)</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>WALMART_CONSUMER_ID</Name>
      <Mode/>
      <Description>Walmart Open API Consumer ID — developer.walmart.com</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <Variable>
      <Value></Value>
      <Name>WALMART_PRIVATE_KEY</Name>
      <Mode/>
      <Description>Walmart Open API Private Key (RSA, base64-encoded)</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>true</Mask>
    </Variable>

    <!-- ── Rate Limiting ── -->
    <Variable>
      <Value>10</Value>
      <Name>SEARCH_RATE_LIMIT_PER_MINUTE</Name>
      <Mode/>
      <Description>Max searches per minute per IP</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

    <Variable>
      <Value>200</Value>
      <Name>SEARCH_RATE_LIMIT_PER_DAY</Name>
      <Mode/>
      <Description>Max searches per day per IP</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>

    <!-- ── Internal (pre-filled, no need to change) ── -->
    <Variable>
      <Value>postgres</Value>
      <Name>POSTGRES_HOST</Name>
      <Mode/>
      <Description>Internal PostgreSQL hostname (do not change)</Description>
      <Display>advanced</Display>
      <Required>true</Required>
      <Mask>false</Mask>
    </Variable>

    <Variable>
      <Value>redis</Value>
      <Name>REDIS_HOST</Name>
      <Mode/>
      <Description>Internal Redis hostname (do not change)</Description>
      <Display>advanced</Display>
      <Required>true</Required>
      <Mask>false</Mask>
    </Variable>

  </Environment>

  <Labels/>
  <Config Name="Web UI Port" Target="80" Default="8090" Mode="tcp" Description="Port to access the Shopping Companion web UI" Type="Port" Display="always" Required="true" Mask="false">8090</Config>
  <Config Name="AppData - PostgreSQL" Target="/var/lib/postgresql/data" Default="/mnt/user/appdata/shopping-companion/postgres" Mode="rw" Description="PostgreSQL data directory" Type="Path" Display="advanced" Required="true" Mask="false">/mnt/user/appdata/shopping-companion/postgres</Config>
  <Config Name="AppData - Redis" Target="/data" Default="/mnt/user/appdata/shopping-companion/redis" Mode="rw" Description="Redis persistence directory" Type="Path" Display="advanced" Required="true" Mask="false">/mnt/user/appdata/shopping-companion/redis</Config>

</Container>
